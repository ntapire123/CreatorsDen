MONGODB_URI=mongodb://127.0.0.1:27017/creatorsden
JWT_SECRET=replace_with_strong_secret
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ENABLE_SYNC_SCHEDULER=false
SYNC_CRON_EXPRESSION=0 */3 * * *
SYNC_MIN_INTERVAL_MINUTES=180
RAPIDAPI_KEY=replace_with_rapidapi_key
RAPIDAPI_TIKTOK_HOST=tiktok-api23.p.rapidapi.com
RAPIDAPI_TIKTOK_ENDPOINT=/api/user/info-with-region
RAPIDAPI_TIKTOK_POSTS_COUNT=35
RAPIDAPI_TIKTOK_MAX_PAGES=6
TIKTOK_ENGAGEMENT_CACHE_MS=300000
RAPIDAPI_INSTA_HOST=instagram-scraper-stable-api.p.rapidapi.com
RAPIDAPI_INSTA_ENDPOINT=/ig_get_fb_profile_v3.php
RAPIDAPI_INSTA_POSTS_AMOUNT=12
RAPIDAPI_INSTA_REELS_AMOUNT=20
INSTAGRAM_ENGAGEMENT_CACHE_MS=300000
YOUTUBE_API_KEY=replace_with_youtube_api_key
